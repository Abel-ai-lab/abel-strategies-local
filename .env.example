# Optional environment values for local refreshes.
# Copy to .env for local use; .env is ignored and must not be committed.

# Router PostgreSQL config path. Defaults to config/router.prod.local.yaml when omitted.
ROUTER_CONFIG=config/router.prod.local.yaml

# CHFS config path for trade-log downloads.
CHFS_CONFIG=config/chfs.sit.local.yaml

# CAP market/day_bar API access for portfolio benchmark bars.
CAP_API_KEY=replace-with-local-key
CAP_BASE_URL=https://cap.example.com/api

# Abel admin publish API for optional portfolio creation/update.
# Use the Router base URL; the script appends /web/skill-dashboard/admin.
ABEL_ADMIN_BASE_URL=https://router.example.com
ABEL_ADMIN_API_KEY=replace-with-local-admin-api-key

# Optional selection inputs.
SELECTION_CSV=references/preferred_selection.csv
PREFERRED_SELECTION_CSV=references/preferred_selection.csv

# Optional refresh controls.
BASE_STRATEGY_IDS_PATH=
EXTRA_STRATEGY_COUNT=0
EXTRA_TARGET_ASSETS=
